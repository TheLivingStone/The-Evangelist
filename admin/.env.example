# =====================================================================
# The Evangelist — Admin dashboard config.  Copy to `.env.local`.
#
# SECURITY: none of these have the NEXT_PUBLIC_ prefix, so Next.js keeps
# them SERVER-SIDE ONLY. They are never sent to the browser. Do NOT add a
# NEXT_PUBLIC_ prefix to the service-role key or the admin password.
# =====================================================================

# Your Supabase project URL (same one the app uses). Safe/public.
SUPABASE_URL=https://ryufvbhddsntcrvpkpet.supabase.co

# Supabase SERVICE-ROLE key. Bypasses RLS — full read/write to every table.
# Find it: Supabase Dashboard → Project Settings → API → service_role (secret).
# Server-only. If this ever leaks, rotate it immediately in the dashboard.
SUPABASE_SERVICE_ROLE_KEY=paste-the-service_role-secret-here

# The password you (the owners) type to log into this dashboard. Pick a long,
# random one. Anyone with this password can see/moderate everything.
ADMIN_PASSWORD=change-me-to-a-long-random-passphrase

# A random secret used to sign the admin session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=generate-a-64-char-hex-string
