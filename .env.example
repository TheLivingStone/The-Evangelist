# =============================================================================
# The Evangelist — environment configuration
# =============================================================================
# There are two different env files. Keep public and secret values separate.
#
#  • app/.env  — bundled INTO the Flutter app (iOS/Android/web) and read at
#                runtime via flutter_dotenv. ONLY public, client-safe keys.
#                Gitignored. Copy the "CLIENT-SAFE" block below into it.
#
#  • this file / root .env — server-side secrets (Clerk secret key, etc.) used
#                by edge functions / webhooks. NEVER bundled into the app.
# =============================================================================

# ---------- CLIENT-SAFE (goes in app/.env) ----------
# Keep false while developing against the in-memory local repositories.
# Set true when Clerk + Supabase are ready to be enabled again.
BACKEND_ENABLED=false
# Clerk publishable key — identity provider. Public by design.
CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>

# Supabase — data backend. The key is the publishable/anon key (public).
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — only when the native Google Map is wired up.
GOOGLE_MAPS_API_KEY=

# ---------- SERVER-ONLY SECRETS (never put in app/.env or client code) ----------
# Clerk secret key — backend only (edge functions, Clerk webhook verification).
CLERK_SECRET_KEY=<your-clerk-secret-key>

# Clerk domain (Frontend API host) — paste this into Supabase:
# Dashboard → Authentication → Sign In / Providers → Add provider → Clerk.
# It is encoded in the publishable key; for the example key above it would be
# something like:  your-app-12.clerk.accounts.dev
